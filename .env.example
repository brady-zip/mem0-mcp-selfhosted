# mem0-mcp-selfhosted environment variables
# Copy to .env and fill in values. Never commit .env with real secrets.

# --- LLM Provider ---
# MEM0_LLM_PROVIDER=anthropic          # anthropic | ollama | openai
# MEM0_LLM_MODEL=claude-opus-4-6       # Model name (default depends on provider)
# MEM0_LLM_MAX_TOKENS=16384
# MEM0_LLM_URL=http://localhost:11434   # Ollama base URL (only for ollama provider)

# --- Anthropic Auth (pick one) ---
# MEM0_ANTHROPIC_TOKEN=               # OAuth/OAT token (highest priority)
# ANTHROPIC_API_KEY=                   # Standard API key (fallback)

# --- OpenAI Auth (only for the openai LLM/embedder provider) ---
# OPENAI_API_KEY=                      # Used by BOTH the openai LLM and embedder

# --- Embedder ---
# MEM0_EMBED_PROVIDER=ollama           # ollama | openai
# MEM0_EMBED_MODEL=bge-m3
# MEM0_EMBED_URL=http://localhost:11434
# MEM0_EMBED_DIMS=1024

# --- Vector Store (Qdrant) ---
# MEM0_QDRANT_URL=http://localhost:6333   # Qdrant server URL (server mode)
# MEM0_COLLECTION=mem0_mcp_selfhosted
# MEM0_QDRANT_API_KEY=
# MEM0_QDRANT_ON_DISK=false
# MEM0_QDRANT_PATH=                       # Embedded mode: when set, runs an on-disk,
#                                         # server-less Qdrant at this local path (e.g.
#                                         # ~/.local/share/mem0/qdrant). Takes precedence
#                                         # over MEM0_QDRANT_URL — no Qdrant server / Docker.

# --- Graph Store (Neo4j) ---
# MEM0_ENABLE_GRAPH=false
# MEM0_NEO4J_URL=bolt://127.0.0.1:7687
# MEM0_NEO4J_USER=neo4j
# MEM0_NEO4J_PASSWORD=mem0graph
# MEM0_NEO4J_DATABASE=
# MEM0_NEO4J_BASE_LABEL=
# MEM0_GRAPH_THRESHOLD=0.7

# --- Graph LLM ---
# MEM0_GRAPH_LLM_PROVIDER=anthropic    # anthropic | ollama | gemini | gemini_split
# MEM0_GRAPH_LLM_MODEL=                # Defaults to MEM0_LLM_MODEL
# MEM0_GRAPH_LLM_URL=                  # Defaults to MEM0_LLM_URL (ollama only)

# --- Gemini (for graph LLM) ---
# GOOGLE_API_KEY=

# --- Split-model Graph LLM (gemini_split) ---
# MEM0_GRAPH_CONTRADICTION_LLM_PROVIDER=anthropic
# MEM0_GRAPH_CONTRADICTION_LLM_MODEL=

# --- Server ---
# MEM0_HOST=0.0.0.0
# MEM0_PORT=8081
# MEM0_TRANSPORT=stdio                 # stdio | sse | streamable-http
# MEM0_LOG_LEVEL=INFO

# --- Memory Defaults ---
# MEM0_USER_ID=default
# MEM0_HISTORY_DB_PATH=

# --- Auto-hook app_id partitioning (optional; SessionStart/Stop hooks only) ---
# Both default to off — when unset the hooks behave exactly as before (no app_id
# on capture; recall filters on user_id alone). Set them to partition memory by
# domain. The hook wrapper scripts typically export these per-session from the cwd.
# MEM0_APP_ID=                          # capture: tag stop-hook memories with this app_id
# MEM0_RECALL_APP_IDS=                  # recall: comma-separated app_ids to scope SessionStart
#                                       # recall to (searched per-id, merged/deduped)
